---
import App from '../components/App';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/nbalternate/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>NBAalternate — Parallel Universe Playoffs</title>
    <meta name="description" content="What if NBA history went differently? Simulate alternate universe playoffs with real rosters and box scores." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Oswald:wght@400;500;600;700&family=Roboto+Condensed:wght@300;400;700&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      html, body {
        background: #080E1A;
        color: #fff;
        font-family: 'Roboto Condensed', 'Arial Narrow', sans-serif;
        min-height: 100vh;
        overflow-x: hidden;
      }

      /* Hardwood plank lines */
      body::before {
        content: '';
        position: fixed;
        inset: 0;
        background-image: repeating-linear-gradient(
          90deg,
          transparent 0px,
          transparent 59px,
          rgba(139,94,60,0.03) 59px,
          rgba(139,94,60,0.03) 60px
        );
        pointer-events: none;
        z-index: 0;
      }

      #app-root {
        position: relative;
        z-index: 1;
      }

      ::-webkit-scrollbar        { width: 5px; height: 5px; }
      ::-webkit-scrollbar-track  { background: #080E1A; }
      ::-webkit-scrollbar-thumb  { background: #1E2A3D; border-radius: 3px; }

      input[type=range] {
        -webkit-appearance: none;
        appearance: none;
        height: 3px;
        border-radius: 2px;
        background: #1E2A3D;
        outline: none;
        width: 100%;
      }
      input[type=range]::-webkit-slider-thumb {
        -webkit-appearance: none;
        width: 22px; height: 22px;
        border-radius: 50%;
        background: #C8102E;
        cursor: pointer;
        border: 3px solid #fff;
        box-shadow: 0 0 0 2px #C8102E, 0 0 12px rgba(200,16,46,0.5);
        transition: box-shadow 0.2s;
      }
      input[type=range]::-webkit-slider-thumb:hover {
        box-shadow: 0 0 0 2px #C8102E, 0 0 20px rgba(200,16,46,0.7);
      }
    </style>
  </head>
  <body>
    <div id="app-root">
      <App client:load />
    </div>
  </body>
</html>
