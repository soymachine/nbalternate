export type RosterEntry = {
  name: string;
  pos: 'PG' | 'SG' | 'SF' | 'PF' | 'C';
  // Optional real season averages — when present, override position archetypes
  pts?: number;   // points per game
  reb?: number;   // rebounds per game
  ast?: number;   // assists per game
  stl?: number;   // steals per game
  blk?: number;   // blocks per game
  min?: number;   // minutes per game
  fgPct?: number; // field goal %
  fg3Pct?: number;// 3-point %
  ftPct?: number; // free throw %
};
export type HistoricalRosters = Record<string, Record<string, RosterEntry[]>>;

